-- Teleport and Fetch Logic
local isFetching = false

local function fetchItem(itemName, targetCoord, btn)
    if isFetching then return end
    isFetching = true
    
    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then 
        isFetching = false 
        return 
    end

    btn.Text = "FETCHING..."
    btn.BackgroundColor3 = Color3.fromRGB(150, 150, 40)
    
    -- 1. Save original pos
    local originalCFrame = char:GetPivot()
    
    -- 2. Teleport to target
    char:PivotTo(CFrame.new(targetCoord))
    task.wait(0.1) -- Give the server time to register your new physical location
    
    -- 3. Find Item(s) and Fire Prompt
    local found = false
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == itemName then
            local pp = obj:FindFirstChild("PP", true)
            
            if pp and pp:IsA("ProximityPrompt") then
                -- SECURITY BYPASS: Force the prompt to be interactable from anywhere and through walls
                pp.RequiresLineOfSight = false
                pp.MaxActivationDistance = 50 
                pp.HoldDuration = 0
                
                task.wait(0.1)
                pcall(function()
                    fireproximityprompt(pp)
                end)
                found = true
                -- We intentionally DO NOT break here. If there are multiple items with the same name, we fire them all.
            end
        end
    end
    
    task.wait(0.3) -- Wait half a second before teleporting back to ensure the item enters the inventory
    
    -- 4. Teleport Back
    char:PivotTo(originalCFrame)
    
    if found then
        btn.Text = "SUCCESS"
        btn.BackgroundColor3 = Color3.fromRGB(40, 150, 40)
    else
        btn.Text = "NOT FOUND"
        btn.BackgroundColor3 = Color3.fromRGB(150, 40, 40)
    end
    
    task.delay(0.3, function()
        if btn then
            btn.Text = "Get : " .. itemName
            btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        end
        isFetching = false
    end)
end

