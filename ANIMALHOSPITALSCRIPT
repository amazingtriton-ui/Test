local function coffeeRoutine()
    while autoCoffee do
        pcall(function()
            local machine = workspace.Misc:FindFirstChild("CoffeeMachine")
            
            -- FIX: Check if Brewing is false (done) AND the coffee prompt is enabled
            if machine and machine:GetAttribute("Brewing") == false then
                local coffee = machine:FindFirstChild("Coffee")
                if coffee and coffee:FindFirstChild("PP") and coffee.PP.Enabled then
                    local char = LocalPlayer.Character
                    if char and char.PrimaryPart then
                        -- 1. Save your original position
                        local originalCFrame = char:GetPivot()
                        
                        -- 2. Teleport to the coffee machine
                        tp(-119, 3.5, 11) 
                        task.wait(0.3)
                        
                        -- 3. Grab the coffee
                        firePrompt(coffee.PP)
                        task.wait(0.3)
                        
                        -- 4. Teleport back to original position
                        char:PivotTo(originalCFrame)
                        
                        task.wait(1) 
                    end
                end
            end
        end)
        task.wait(0.5) 
    end
end

