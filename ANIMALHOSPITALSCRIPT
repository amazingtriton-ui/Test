-- The Auto Equip Logic
local autoEquip = false
local backpackConnection = nil
local characterConnection = nil

-- The exact list of items to look for (Added singular versions just in case)
local allowedItems = {
    ["Eye Drops"] = true,
    ["IV Drops"] = true,
    ["Medkit"] = true,
    ["Thermo"] = true,
    ["Ointment"] = true,
    ["Bandages"] = true,
    ["Bandage"] = true, 
    ["Maple Syrup"] = true,
    ["Cough Syrup"] = true,
    ["Medicine"] = true,
    ["Herbs"] = true,
    ["Herb"] = true
}

local function equipTool(tool)
    if not autoEquip then return end
    
    local char = LocalPlayer.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid and allowedItems[tool.Name] then
            -- Small delay ensures the tool is fully loaded before the game tries to equip it
            task.wait(0.05)
            humanoid:EquipTool(tool)
        end
    end
end

local function checkExistingItems()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and allowedItems[tool.Name] then
                equipTool(tool)
            end
        end
    end
end

local function setupBackpackListener(character)
    if backpackConnection then backpackConnection:Disconnect() end
    
    local backpack = LocalPlayer:WaitForChild("Backpack", 5)
    if backpack then
        backpackConnection = backpack.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then
                equipTool(child)
            end
        end)
    end
end

ToggleBtn.MouseButton1Click:Connect(function()
    autoEquip = not autoEquip
    if autoEquip then
        ToggleBtn.Text = "Auto Equip Items: ON"
        ToggleBtn.TextColor3 = Color3.fromRGB(80, 255, 80)
        
        -- Check if you already have the items in your inventory right now
        checkExistingItems()
        
        -- Start listening for new items
        if LocalPlayer.Character then
            setupBackpackListener(LocalPlayer.Character)
        end
        
        -- Make sure it keeps working if you die/respawn
        if not characterConnection then
            characterConnection = LocalPlayer.CharacterAdded:Connect(function(char)
                if autoEquip then
                    setupBackpackListener(char)
                end
            end)
        end
    else
        ToggleBtn.Text = "Auto Equip Items: OFF"
        ToggleBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
        
        if backpackConnection then
            backpackConnection:Disconnect()
            backpackConnection = nil
        end
    end
end)

