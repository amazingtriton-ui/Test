local function fuzzyColorMatch(c1, c2)
    -- Fallback in case exact equality fails due to float imprecision
    return math.abs(c1.R - c2.R) < 0.01 and math.abs(c1.G - c2.G) < 0.01 and math.abs(c1.B - c2.B) < 0.01
end

task.spawn(function()
    local path = workspace:WaitForChild("Rooms", 10)
    if not path then return end
    
    local emergency = path:WaitForChild("Emergency", 10)
    local room6 = emergency and emergency:WaitForChild("Room6", 10)
    local minigame = room6 and room6:WaitForChild("Minigame", 10)
    local colorsFolder = minigame and minigame:WaitForChild("Colors", 10)
    
    if colorsFolder then
        for _, model in ipairs(colorsFolder:GetChildren()) do
            local button = model:FindFirstChild("Button")
            if button and button:IsA("BasePart") then
                button:GetPropertyChangedSignal("Color"):Connect(function()
                    local mainColor = button:GetAttribute("MainColor")
                    if mainColor and typeof(mainColor) == "Color3" then
                        if button.Color == mainColor or fuzzyColorMatch(button.Color, mainColor) then
                            sequenceCount = sequenceCount + 1
                            table.insert(sequenceLog, {
                                name = model.Name,
                                color = mainColor
                            })
                            UpdateLogUI()
                        end
                    end
                end)
            end
        end
    end
end)

