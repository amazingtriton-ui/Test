espFolder.Name = "NPC_ESP_Folder"
espFolder.Parent = guiParent

local espCache = {}

local function getRoot(character)
    return character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Head") or character.PrimaryPart
end

local function createESP(npc)
    local root = getRoot(npc)
    if not root then return end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = npc.Name .. "_TextESP"
    billboard.Adornee = root
    billboard.Size = UDim2.new(0, 400, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3.5, 0)
    billboard.AlwaysOnTop = true
    billboard.LightInfluence = 0 

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.TextScaled = false
    textLabel.TextSize = 14
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextStrokeTransparency = 0
    textLabel.Parent = billboard
    billboard.Parent = espFolder

    local highlight = Instance.new("Highlight")
    highlight.Name = npc.Name .. "_BodyESP"
    highlight.Adornee = npc 
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Parent = espFolder

    espCache[npc] = {Gui = billboard, Label = textLabel, Highlight = highlight}
end

RunService.RenderStepped:Connect(function()
    local myRoot = LocalPlayer.Character and getRoot(LocalPlayer.Character)
    
    for npc, espData in pairs(espCache) do
        if not npc or not npc.Parent then
            espData.Gui:Destroy()
            espData.Highlight:Destroy()
            espCache[npc] = nil
        end
    end

    for _, npc in ipairs(NPCsFolder:GetChildren()) do
        if not espCache[npc] then
            createESP(npc)
        end

        local espData = espCache[npc]
        if espData then
            local root = getRoot(npc)
            if root and myRoot then
                local dist = math.floor((myRoot.Position - root.Position).Magnitude)
                
                local skinwalkerAttr = npc:GetAttribute("Skinwalker")
                local isAnomaly = (skinwalkerAttr == true) 
                
                local statusText = isAnomaly and "anomaly" or "innocent"
                local color = isAnomaly and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(50, 255, 50)
                
                local roomAttr = npc:GetAttribute("designatedRoom")
                local roomText = "Unknown"
                
                if roomAttr then
                    -- string.match("%d+") extracts only the numbers from the text (e.g. "Room15" -> "15")
                    local extractedNumber = string.match(tostring(roomAttr), "%d+")
                    roomText = extractedNumber and extractedNumber or tostring(roomAttr)
                end

                espData.Label.Text = string.format("%s | %d studs | %s | Room: %s", npc.Name, dist, statusText, roomText)
                espData.Label.TextColor3 = color

                espData.Highlight.FillColor = color
                espData.Highlight.OutlineColor = color
            end
        end
    end
end)

